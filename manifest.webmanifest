<!doctype html>
<html lang="pt-PT" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#05070b" />
  <title>PSI Broker Mobile — Bolsa de Lisboa</title>
  <meta name="description" content="Versão smartphone de dashboard estilo corretora para acompanhar cotações do PSI na Bolsa de Lisboa." />
  <link rel="manifest" href="manifest.webmanifest" />
  <link rel="icon" type="image/png" sizes="192x192" href="icons/icon-192.png" />
  <link rel="icon" type="image/png" sizes="512x512" href="icons/icon-512.png" />
  <link rel="apple-touch-icon" href="icons/icon-192.png" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="application-name" content="PSI Broker" />

  <style>
    :root{
      color-scheme:dark;
      --bg:#05070b; --bg2:#080d14; --panel:#0b121c; --panel2:#101927; --panel3:#172234;
      --line:#1e2a3b; --line2:#314157; --text:#eef4fb; --muted:#8d9bb0; --muted2:#b7c3d4;
      --green:#18c77d; --greenBg:rgba(24,199,125,.13); --red:#ff5470; --redBg:rgba(255,84,112,.13);
      --amber:#f6bd60; --blue:#4aa3ff; --violet:#9b7cff; --shadow:0 18px 50px rgba(0,0,0,.45);
      --mono:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace;
      --sans:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
      --safeTop:env(safe-area-inset-top,0px); --safeBottom:env(safe-area-inset-bottom,0px);
    }
    :root[data-theme="light"]{
      color-scheme:light; --bg:#eef2f6; --bg2:#dfe7f1; --panel:#fff; --panel2:#f8fafc; --panel3:#eef3f8;
      --line:#d7e0ec; --line2:#acb9c9; --text:#101828; --muted:#667085; --muted2:#344054;
      --shadow:0 18px 45px rgba(15,23,42,.14);
    }
    *{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
    html,body{margin:0;min-height:100%;background:var(--bg);font-family:var(--sans);color:var(--text);font-size:13px;overflow-x:hidden}
    body{background:radial-gradient(circle at 20% -10%,rgba(74,163,255,.18),transparent 32%),radial-gradient(circle at 100% 0,rgba(24,199,125,.11),transparent 30%),linear-gradient(160deg,var(--bg),var(--bg2));}
    button,input,select{font:inherit;color:var(--text);background:var(--panel2);border:1px solid var(--line);border-radius:12px;outline:none}
    button,select{cursor:pointer} button:disabled{opacity:.55;cursor:not-allowed} a{color:inherit;text-decoration:none}
    .mobile-shell{width:min(100%,460px);min-height:100dvh;margin:0 auto;position:relative;background:linear-gradient(180deg,rgba(255,255,255,.02),transparent 260px);box-shadow:0 0 0 1px rgba(255,255,255,.04)}
    .appbar{position:sticky;top:0;z-index:40;padding:calc(8px + var(--safeTop)) 10px 8px;background:linear-gradient(180deg,color-mix(in srgb,var(--panel) 94%,transparent),color-mix(in srgb,var(--panel) 84%,transparent));backdrop-filter:blur(18px);border-bottom:1px solid var(--line)}
    .bar-row{height:42px;display:flex;align-items:center;gap:8px}.brand{display:flex;align-items:center;gap:8px;min-width:0;flex:1}.mark{width:34px;height:34px;border-radius:11px;display:grid;place-items:center;font-weight:950;letter-spacing:-.09em;color:#021018;background:linear-gradient(135deg,#4aa3ff,#18c77d 58%,#d7ffe9);box-shadow:0 0 0 1px rgba(255,255,255,.22) inset,0 10px 28px rgba(24,199,125,.18)}
    .brand-title{min-width:0}.brand h1{margin:0;font-size:.92rem;letter-spacing:-.03em;line-height:1}.brand small{display:block;margin-top:3px;color:var(--muted);font-family:var(--mono);font-size:.66rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .icon-btn{width:38px;height:38px;display:grid;place-items:center;border-radius:12px;font-weight:900}.primary{background:linear-gradient(180deg,color-mix(in srgb,var(--blue) 36%,var(--panel3)),color-mix(in srgb,var(--blue) 15%,var(--panel2)));border-color:color-mix(in srgb,var(--blue) 42%,var(--line))}
    .live-pill{height:30px;display:inline-flex;align-items:center;gap:7px;padding:0 9px;border:1px solid var(--line);border-radius:999px;background:var(--panel2);font-size:.72rem;color:var(--muted2);max-width:128px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}.dot{width:8px;height:8px;border-radius:50%;background:var(--amber);box-shadow:0 0 0 4px rgba(246,189,96,.12);flex:none}.dot.ok{background:var(--green);box-shadow:0 0 0 4px rgba(24,199,125,.13)}.dot.bad{background:var(--red);box-shadow:0 0 0 4px rgba(255,84,112,.13)}
    .ticker{height:34px;display:flex;gap:6px;overflow-x:auto;scrollbar-width:none;padding:2px 0}.ticker::-webkit-scrollbar{display:none}.tape-item{height:28px;display:inline-flex;align-items:center;gap:6px;flex:0 0 auto;padding:0 9px;border:1px solid var(--line);border-radius:999px;background:var(--panel2);font-family:var(--mono);font-size:.72rem}.tape-symbol{font-weight:850;color:var(--muted2)}
    .content{padding:10px 10px calc(78px + var(--safeBottom))}.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:9px}.stat-card{min-height:58px;padding:9px;border:1px solid var(--line);border-radius:14px;background:linear-gradient(180deg,var(--panel2),var(--panel));box-shadow:0 10px 28px rgba(0,0,0,.16)}.stat-card .label{font-size:.63rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);white-space:nowrap}.stat-card .value{margin-top:5px;font-family:var(--mono);font-weight:850;font-size:1rem;letter-spacing:-.02em}.stat-card .note{margin-top:2px;color:var(--muted);font-size:.68rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .controls{display:grid;grid-template-columns:1fr 112px;gap:7px;margin-bottom:9px}.search{height:38px;padding:0 11px}.select{height:38px;padding:0 9px}.segmented{display:flex;gap:6px;margin-bottom:9px;overflow-x:auto;scrollbar-width:none}.segmented::-webkit-scrollbar{display:none}.segmented button{height:34px;padding:0 12px;border-radius:999px;white-space:nowrap;color:var(--muted2);font-weight:750;font-size:.76rem}.segmented button.active{color:var(--text);border-color:color-mix(in srgb,var(--blue) 45%,var(--line));background:color-mix(in srgb,var(--blue) 16%,var(--panel2))}
    .panel{display:none}.panel.active{display:block}.quote-list{display:grid;gap:6px}.quote-card{width:100%;display:grid;grid-template-columns:minmax(0,1.15fr) auto 76px;gap:8px;align-items:center;text-align:left;padding:8px 9px;border:1px solid var(--line);border-radius:13px;background:linear-gradient(180deg,var(--panel2),var(--panel));min-height:58px}.quote-card.selected{border-color:color-mix(in srgb,var(--blue) 55%,var(--line));box-shadow:0 0 0 1px color-mix(in srgb,var(--blue) 22%,transparent) inset}.q-main{min-width:0}.q-symbol{font-family:var(--mono);font-size:.88rem;font-weight:900}.q-name{margin-top:2px;color:var(--muted);font-size:.72rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.q-price{text-align:right;font-family:var(--mono);font-size:.94rem;font-weight:900}.q-change{text-align:right;font-family:var(--mono);font-size:.78rem;margin-top:2px}.spark{width:74px;height:30px}.spark svg{width:74px;height:30px;display:block}.spark path{fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round}.spark .fill{stroke:none;opacity:.1}.pos{color:var(--green)!important}.neg{color:var(--red)!important}.flat{color:var(--muted)!important}
    .detail-hero{border:1px solid var(--line);border-radius:18px;background:linear-gradient(180deg,var(--panel2),var(--panel));box-shadow:var(--shadow);overflow:hidden}.detail-head{padding:12px 12px 8px;display:flex;align-items:flex-start;gap:10px}.logo{width:40px;height:40px;border-radius:13px;display:grid;place-items:center;background:var(--panel3);border:1px solid var(--line);font-family:var(--mono);font-weight:900}.detail-title{min-width:0;flex:1}.detail-title h2{margin:0;font-size:1rem;line-height:1.1}.detail-title small{display:block;margin-top:4px;color:var(--muted);font-family:var(--mono);font-size:.68rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.status-chip{height:25px;display:inline-flex;align-items:center;padding:0 8px;border-radius:999px;border:1px solid var(--line);font-size:.68rem;color:var(--muted2);white-space:nowrap}.detail-price{padding:0 12px 8px}.last-price{font-family:var(--mono);font-size:2rem;font-weight:950;letter-spacing:-.06em}.change-pill{display:inline-flex;margin-top:5px;height:28px;align-items:center;padding:0 10px;border-radius:999px;font-family:var(--mono);font-weight:850;background:var(--panel3);border:1px solid var(--line)}.chart-wrap{height:152px;border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:rgba(0,0,0,.1);padding:8px}.chart-wrap svg{width:100%;height:100%}.grid-line{stroke:var(--line);stroke-width:1}.chart-path{fill:none;stroke-width:2.6;stroke-linecap:round;stroke-linejoin:round}.chart-fill{opacity:.1}.metrics{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line)}.metric{background:var(--panel);padding:9px 10px}.metric span{display:block;color:var(--muted);font-size:.64rem;text-transform:uppercase;letter-spacing:.08em}.metric strong{display:block;margin-top:4px;font-family:var(--mono);font-size:.86rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.actions{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;padding:10px}.action-link{height:36px;display:grid;place-items:center;border:1px solid var(--line);border-radius:12px;background:var(--panel2);font-weight:800;font-size:.76rem}
    .ticket{display:grid;gap:9px}.ticket-card{border:1px solid var(--line);border-radius:16px;background:linear-gradient(180deg,var(--panel2),var(--panel));padding:10px}.ticket-title{display:flex;justify-content:space-between;align-items:center;margin-bottom:9px}.ticket-title h3{margin:0;font-size:.85rem;text-transform:uppercase;letter-spacing:.08em}.note{color:var(--muted);font-size:.72rem}.side-tabs{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:9px}.side-tabs button{height:39px;font-weight:950}.buy{background:color-mix(in srgb,var(--green) 15%,var(--panel2));border-color:color-mix(in srgb,var(--green) 44%,var(--line))}.sell{background:color-mix(in srgb,var(--red) 14%,var(--panel2));border-color:color-mix(in srgb,var(--red) 44%,var(--line))}.field-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}.field label{display:block;margin:0 0 4px;color:var(--muted);font-size:.65rem;text-transform:uppercase;letter-spacing:.08em}.field input,.field select{width:100%;height:38px;padding:0 10px;font-family:var(--mono)}.estimate{margin-top:9px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px}.estimate div{padding:8px;border:1px solid var(--line);border-radius:12px;background:var(--panel2)}.estimate span{display:block;color:var(--muted);font-size:.62rem;text-transform:uppercase}.estimate strong{display:block;margin-top:3px;font-family:var(--mono);font-size:.78rem}.disabled-order{width:100%;height:40px;margin-top:9px;font-weight:900}.warning{margin-top:8px;color:var(--amber);font-size:.72rem;line-height:1.35}.book{display:grid;grid-template-columns:1fr 1fr;gap:8px}.book table{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:.72rem}.book th,.book td{padding:5px 3px;border-bottom:1px solid var(--line);text-align:right}.depth{height:3px;background:var(--panel3);border-radius:999px;overflow:hidden;margin-top:3px}.depth span{display:block;height:100%;border-radius:999px;opacity:.75}
    .settings-card{border:1px solid var(--line);border-radius:16px;background:linear-gradient(180deg,var(--panel2),var(--panel));padding:10px;margin-bottom:9px}.settings-card h3{margin:0 0 8px;font-size:.86rem}.settings-grid{display:grid;gap:8px}.settings-grid select,.settings-grid input{width:100%;height:40px;padding:0 10px}.row-actions{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px}.wide-btn{height:40px;padding:0 10px;font-weight:850}.small-copy{color:var(--muted);font-size:.73rem;line-height:1.45;margin:8px 0 0}.log{display:grid;gap:6px}.log-item{padding:8px;border:1px solid var(--line);border-radius:12px;background:var(--panel2)}.log-title{font-weight:800}.log-meta{margin-top:3px;color:var(--muted);font-size:.7rem}
    .bottom-nav{position:fixed;left:50%;transform:translateX(-50%);bottom:0;z-index:45;width:min(100%,460px);padding:8px 9px calc(8px + var(--safeBottom));display:grid;grid-template-columns:repeat(4,1fr);gap:6px;background:linear-gradient(180deg,color-mix(in srgb,var(--panel) 80%,transparent),var(--panel));border-top:1px solid var(--line);backdrop-filter:blur(18px)}.tab-btn{height:48px;border-radius:14px;display:grid;place-items:center;color:var(--muted);font-size:.7rem;font-weight:850}.tab-btn b{display:block;font-size:1rem;line-height:1}.tab-btn.active{color:var(--text);border-color:color-mix(in srgb,var(--blue) 40%,var(--line));background:color-mix(in srgb,var(--blue) 14%,var(--panel2))}.float-refresh{position:fixed;right:max(13px,calc((100vw - 460px)/2 + 13px));bottom:calc(74px + var(--safeBottom));z-index:44;width:52px;height:52px;border-radius:18px;box-shadow:0 14px 36px rgba(0,0,0,.35);font-size:1.15rem}
    dialog{width:min(94vw,430px);border:1px solid var(--line);border-radius:20px;background:var(--panel);color:var(--text);box-shadow:var(--shadow);padding:0}dialog::backdrop{background:rgba(0,0,0,.65);backdrop-filter:blur(4px)}.dialog-head{display:flex;justify-content:space-between;align-items:center;padding:11px;border-bottom:1px solid var(--line)}.dialog-head h3{margin:0}.dialog-body{padding:11px}.dialog-body textarea{width:100%;min-height:210px;resize:vertical;border:1px solid var(--line);border-radius:12px;background:#05070b;color:#d8e1ec;padding:10px;font-family:var(--mono);font-size:.72rem;line-height:1.35}

    .install-app-btn{position:fixed;left:max(13px,calc((100vw - 460px)/2 + 13px));bottom:calc(74px + var(--safeBottom));z-index:44;height:52px;padding:0 14px;border-radius:18px;box-shadow:0 14px 36px rgba(0,0,0,.35);font-weight:950;display:none;background:linear-gradient(180deg,color-mix(in srgb,var(--green) 34%,var(--panel3)),color-mix(in srgb,var(--green) 15%,var(--panel2)));border-color:color-mix(in srgb,var(--green) 50%,var(--line))}.install-app-btn.show{display:inline-flex;align-items:center;gap:7px}.standalone .install-app-btn{display:none!important}
    @media (min-width:700px){body{padding:18px 0}.mobile-shell{border-radius:30px;overflow:hidden;min-height:calc(100dvh - 36px);border:1px solid var(--line)}.appbar{top:0}.bottom-nav{border-radius:0 0 30px 30px}.float-refresh{right:calc((100vw - 460px)/2 + 13px)}}
  </style>
</head>
<body>
  <div class="mobile-shell">
    <header class="appbar">
      <div class="bar-row">
        <div class="brand">
          <div class="mark">PS</div>
          <div class="brand-title"><h1>PSI Broker Mobile</h1><small id="subtitle">Bolsa de Lisboa · terminal móvel</small></div>
        </div>
        <span class="live-pill"><span id="statusDot" class="dot"></span><span id="statusText">A iniciar…</span></span>
        <button id="refreshBtn" class="icon-btn primary" type="button" aria-label="Atualizar">↻</button>
      </div>
      <div id="tickerTape" class="ticker" aria-label="Fita de mercado"></div>
    </header>

    <main class="content">
      <section class="stat-grid" aria-label="Resumo de mercado">
        <div class="stat-card"><div class="label">PSI</div><div id="mIndex" class="value">—</div><div id="mState" class="note">Mercado —</div></div>
        <div class="stat-card"><div class="label">Breadth</div><div id="mBreadth" class="value">—</div><div id="mBreadthNote" class="note">—</div></div>
        <div class="stat-card"><div class="label">Dados</div><div id="mQuality" class="value">—</div><div id="mSource" class="note">Yahoo Chart</div></div>
        <div class="stat-card"><div class="label">Volume</div><div id="mVolume" class="value">—</div><div class="note">Última: <span id="lastUpdate">—</span></div></div>
      </section>

      <section id="panel-watch" class="panel active" aria-label="Watchlist">
        <div class="controls">
          <input id="searchInput" class="search" placeholder="Pesquisar cotada, ticker ou ISIN…" />
          <select id="filterSelect" class="select"><option value="all">Todas</option><option value="up">A subir</option><option value="down">A descer</option><option value="with-data">Com dados</option><option value="errors">Erros</option></select>
        </div>
        <div class="segmented" aria-label="Ordenação rápida">
          <button data-sortquick="name" class="active">Nome</button><button data-sortquick="changePercent">Variação</button><button data-sortquick="volume">Volume</button><button data-sortquick="price">Preço</button>
        </div>
        <div id="quoteList" class="quote-list"></div>
      </section>

      <section id="panel-detail" class="panel" aria-label="Detalhe do ativo">
        <article class="detail-hero">
          <div class="detail-head">
            <div id="selectedLogo" class="logo">—</div>
            <div class="detail-title"><h2 id="selectedSymbol">—</h2><small id="selectedName">—</small></div>
            <span id="selectedStatus" class="status-chip">—</span>
          </div>
          <div class="detail-price"><div id="selectedPrice" class="last-price">—</div><div id="selectedChange" class="change-pill flat">—</div></div>
          <div id="bigChart" class="chart-wrap"></div>
          <div class="metrics">
            <div class="metric"><span>Abertura</span><strong id="selectedOpen">—</strong></div>
            <div class="metric"><span>Máximo</span><strong id="selectedHigh">—</strong></div>
            <div class="metric"><span>Mínimo</span><strong id="selectedLow">—</strong></div>
            <div class="metric"><span>Fecho ant.</span><strong id="selectedPrev">—</strong></div>
            <div class="metric"><span>Volume</span><strong id="selectedVolume">—</strong></div>
            <div class="metric"><span>Hora</span><strong id="selectedTime">—</strong></div>
            <div class="metric"><span>ISIN</span><strong id="selectedIsin">—</strong></div>
            <div class="metric"><span>Fonte</span><strong id="selectedProvider">—</strong></div>
          </div>
          <div class="actions"><a id="googleLink" class="action-link" target="_blank" rel="noopener">Google</a><a id="yahooLink" class="action-link" target="_blank" rel="noopener">Yahoo</a><a id="euronextLink" class="action-link" target="_blank" rel="noopener">Euronext</a></div>
        </article>
      </section>

      <section id="panel-trade" class="panel" aria-label="Trading visual">
        <div class="ticket">
          <div class="ticket-card">
            <div class="ticket-title"><h3>Order Ticket</h3><span class="note">simulado</span></div>
            <div class="side-tabs"><button id="buyTab" class="buy" type="button">COMPRA</button><button id="sellTab" class="sell" type="button">VENDA</button></div>
            <div class="field-grid">
              <div class="field"><label>Símbolo</label><input id="ticketSymbol" readonly value="—" /></div>
              <div class="field"><label>Tipo</label><select id="orderType"><option>Limitada</option><option>Mercado</option><option>Stop</option></select></div>
              <div class="field"><label>Quantidade</label><input id="ticketQty" type="number" min="1" step="1" value="100" /></div>
              <div class="field"><label>Limite</label><input id="ticketLimit" type="number" min="0" step="0.0001" /></div>
            </div>
            <div class="estimate"><div><span>Estim.</span><strong id="ticketEstimate">—</strong></div><div><span>Comissões</span><strong>—</strong></div><div><span>Liquidação</span><strong>T+2</strong></div></div>
            <button class="disabled-order primary" disabled>Enviar ordem desativado</button>
            <div class="warning">Painel meramente visual. Não envia ordens nem valida execução real.</div>
          </div>
          <div class="ticket-card">
            <div class="ticket-title"><h3>Market Depth</h3><span class="note">bid/ask estimado</span></div>
            <div id="orderBook" class="book"></div>
          </div>
        </div>
      </section>

      <section id="panel-settings" class="panel" aria-label="Fontes e definições">
        <div class="settings-card">
          <h3>Fonte de dados</h3>
          <div class="settings-grid">
            <select id="providerSelect"><option value="yahoo-chart" selected>Yahoo Chart + fallbacks</option><option value="custom-worker">Proxy próprio</option></select>
            <select id="intervalSelect"><option value="0">Sem auto-refresh</option><option value="30">30 segundos</option><option value="60" selected>1 minuto</option><option value="180">3 minutos</option><option value="300">5 minutos</option></select>
          </div>
          <div class="row-actions"><button id="testBtn" class="wide-btn" type="button">Testar fonte</button><button id="workerBtn" class="wide-btn" type="button">Proxy</button></div>
          <p class="small-copy">HTML mobile sem backend não garante dados em tempo real. Para produção, usa API licenciada ou proxy próprio.</p>
        </div>
        <div class="settings-card">
          <h3>Ações</h3>
          <div class="row-actions"><button id="exportBtn" class="wide-btn" type="button">Exportar CSV</button><button id="themeBtn" class="wide-btn" type="button">Tema claro</button></div>
        </div>
        <div class="settings-card">
          <h3>Activity</h3><div id="activityLog" class="log"></div>
        </div>
      </section>
    </main>

    <button id="floatRefresh" class="float-refresh primary" type="button" aria-label="Atualizar cotações">↻</button>

    <nav class="bottom-nav" aria-label="Navegação principal">
      <button class="tab-btn active" data-tab="watch" type="button"><b>☰</b>Watch</button>
      <button class="tab-btn" data-tab="detail" type="button"><b>⌁</b>Ativo</button>
      <button class="tab-btn" data-tab="trade" type="button"><b>⇄</b>Trade</button>
      <button class="tab-btn" data-tab="settings" type="button"><b>⚙</b>Fonte</button>
    </nav>
  </div>

  <dialog id="workerDialog">
    <div class="dialog-head"><h3>Proxy próprio</h3><button id="closeWorkerBtn" class="icon-btn" type="button">×</button></div>
    <div class="dialog-body">
      <p class="small-copy" style="margin-top:0">Cria um Cloudflare Worker, cola o URL base e usa “Proxy próprio”.</p>
      <input id="workerUrlInput" style="width:100%;height:40px;padding:0 10px;margin-bottom:9px" placeholder="https://o-teu-worker.workers.dev" />
      <textarea id="workerCode" readonly></textarea>
      <button id="saveWorkerBtn" class="wide-btn primary" style="width:100%;margin-top:9px" type="button">Guardar URL</button>
    </div>
  </dialog>

  <script>
  "use strict";
  const INDEX = { name: "PSI", symbol: "PSI20.LS", altSymbols: ["^PSI20"], isin: "PTING0200002", google: "PSI20:INDEXEURO", euronext: "https://live.euronext.com/en/product/indices/PTING0200002-XLIS" };
  const COMPONENTS = [
    { name: "Altri SGPS", symbol: "ALTR.LS", isin: "PTALT0AE0002", google: "ALTR:ELI", euronext: "https://live.euronext.com/en/product/equities/PTALT0AE0002-XLIS" },
    { name: "Banco Comercial Português", symbol: "BCP.LS", isin: "PTBCP0AM0015", google: "BCP:ELI", euronext: "https://live.euronext.com/en/product/equities/PTBCP0AM0015-XLIS" },
    { name: "Corticeira Amorim", symbol: "COR.LS", isin: "PTCOR0AE0006", google: "COR:ELI", euronext: "https://live.euronext.com/en/product/equities/PTCOR0AE0006-XLIS" },
    { name: "CTT Correios de Portugal", symbol: "CTT.LS", isin: "PTCTT0AM0001", google: "CTT:ELI", euronext: "https://live.euronext.com/en/product/equities/PTCTT0AM0001-XLIS" },
    { name: "EDP", symbol: "EDP.LS", isin: "PTEDP0AM0009", google: "EDP:ELI", euronext: "https://live.euronext.com/en/product/equities/PTEDP0AM0009-XLIS" },
    { name: "EDP Renováveis", symbol: "EDPR.LS", isin: "ES0127797019", google: "EDPR:ELI", euronext: "https://live.euronext.com/en/product/equities/ES0127797019-XLIS" },
    { name: "Galp Energia", symbol: "GALP.LS", isin: "PTGAL0AM0009", google: "GALP:ELI", euronext: "https://live.euronext.com/en/product/equities/PTGAL0AM0009-XLIS" },
    { name: "Ibersol", symbol: "IBS.LS", isin: "PTIBS0AM0008", google: "IBS:ELI", euronext: "https://live.euronext.com/en/product/equities/PTIBS0AM0008-XLIS" },
    { name: "Jerónimo Martins", symbol: "JMT.LS", isin: "PTJMT0AE0001", google: "JMT:ELI", euronext: "https://live.euronext.com/en/product/equities/PTJMT0AE0001-XLIS" },
    { name: "Mota-Engil", symbol: "EGL.LS", isin: "PTMEN0AE0005", google: "EGL:ELI", euronext: "https://live.euronext.com/en/product/equities/PTMEN0AE0005-XLIS" },
    { name: "Navigator", symbol: "NVG.LS", isin: "PTPTI0AM0006", google: "NVG:ELI", euronext: "https://live.euronext.com/en/product/equities/PTPTI0AM0006-XLIS" },
    { name: "NOS", symbol: "NOS.LS", isin: "PTZON0AM0006", google: "NOS:ELI", euronext: "https://live.euronext.com/en/product/equities/PTZON0AM0006-XLIS" },
    { name: "REN", symbol: "RENE.LS", altSymbols: ["REN.LS"], isin: "PTREL0AM0008", google: "RENE:ELI", euronext: "https://live.euronext.com/en/product/equities/PTREL0AM0008-XLIS" },
    { name: "Semapa", symbol: "SEM.LS", isin: "PTSEM0AM0004", google: "SEM:ELI", euronext: "https://live.euronext.com/en/product/equities/PTSEM0AM0004-XLIS" },
    { name: "Sonae", symbol: "SON.LS", isin: "PTSON0AM0001", google: "SON:ELI", euronext: "https://live.euronext.com/en/product/equities/PTSON0AM0001-XLIS" },
    { name: "Teixeira Duarte", symbol: "TDSA.LS", isin: "PTTD10AM0000", google: "TDSA:ELI", euronext: "https://live.euronext.com/en/product/equities/PTTD10AM0000-XLIS" }
  ];
  const EMPTY = { price:null, change:null, changePercent:null, open:null, high:null, low:null, prevClose:null, volume:null, time:null, provider:null, marketState:null, history:[], error:"Por atualizar" };
  const state = { rows: COMPONENTS.map(c=>({...c,...EMPTY})), index:{...INDEX,...EMPTY}, selectedSymbol:"BCP.LS", sortKey:"name", sortDir:"asc", timer:null, refreshing:false, side:"buy", tab:"watch" };
  const $ = id => document.getElementById(id);
  const fmtEUR = new Intl.NumberFormat("pt-PT",{style:"currency",currency:"EUR",minimumFractionDigits:2,maximumFractionDigits:4});
  const fmtPrice = new Intl.NumberFormat("pt-PT",{minimumFractionDigits:2,maximumFractionDigits:4});
  const fmtNum = new Intl.NumberFormat("pt-PT",{maximumFractionDigits:2});
  const fmtInt = new Intl.NumberFormat("pt-PT",{maximumFractionDigits:0});
  const fmtPct = new Intl.NumberFormat("pt-PT",{minimumFractionDigits:2,maximumFractionDigits:2});
  function finite(v){return Number.isFinite(Number(v))} function n(v){const x=Number(v);return Number.isFinite(x)?x:null}
  function escapeHtml(v){return String(v??"").replace(/[&<>'"]/g,ch=>({"&":"&amp;","<":"&lt;",">":"&gt;","'":"&#039;",'"':"&quot;"}[ch]))}
  function initials(name){return String(name).split(/\s|-/).filter(Boolean).slice(0,2).map(w=>w[0]).join("").toUpperCase()} function shortSymbol(s){return String(s||"").replace(".LS","")}
  function fEUR(v){return finite(v)?fmtEUR.format(Number(v)):"—"} function fPlain(v){return finite(v)?fmtPrice.format(Number(v)):"—"} function fNum(v){return finite(v)?fmtNum.format(Number(v)):"—"} function fVol(v){return finite(v)?fmtInt.format(Number(v)):"—"}
  function fPct(v){return finite(v)?`${Number(v)>0?"+":""}${fmtPct.format(Number(v))}%`:"—"} function cls(v){return !finite(v)?"flat":Number(v)>0?"pos":Number(v)<0?"neg":"flat"}
  function qTime(ts){const d=ts?new Date(ts*1000):null;return d&&!Number.isNaN(d.getTime())?d:null} function tText(d){return d instanceof Date&&!Number.isNaN(d.getTime())?d.toLocaleString("pt-PT",{dateStyle:"short",timeStyle:"short"}):"—"}
  function yahooChartUrl(symbol,range="1d",interval="1m"){return `https://query2.finance.yahoo.com/v8/finance/chart/${encodeURIComponent(symbol)}?range=${range}&interval=${interval}&includePrePost=false&events=history&corsDomain=finance.yahoo.com`}
  function proxyCandidates(url){return[{name:"Yahoo direto",url},{name:"AllOrigins",url:`https://api.allorigins.win/raw?url=${encodeURIComponent(url)}`},{name:"corsproxy.io",url:`https://corsproxy.io/?${encodeURIComponent(url)}`},{name:"CodeTabs",url:`https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(url)}`},{name:"Jina Reader",url:`https://r.jina.ai/${url}`}]} 
  async function fetchText(url,timeoutMs=12000){const c=new AbortController();const timer=setTimeout(()=>c.abort(),timeoutMs);try{const res=await fetch(url,{signal:c.signal,cache:"no-store",headers:{Accept:"application/json,text/plain,*/*"}});const text=await res.text();if(!res.ok)throw new Error(`HTTP ${res.status}: ${text.slice(0,90)}`);return text}finally{clearTimeout(timer)}}
  function parseJson(text){const clean=String(text||"").trim();try{return JSON.parse(clean)}catch{} const a=clean.indexOf("{"),b=clean.lastIndexOf("}");if(a>=0&&b>a)return JSON.parse(clean.slice(a,b+1));throw new Error("Resposta não é JSON")}
  async function fetchJsonViaFallback(rawUrl){let last=null;for(const cand of proxyCandidates(rawUrl)){try{const text=await fetchText(cand.url);return{json:parseJson(text),provider:cand.name}}catch(e){last=e}}throw last||new Error("Falha desconhecida")}
  function extractChartQuote(data,configuredSymbol,provider){const err=data?.chart?.error;if(err)throw new Error(err.description||err.code||"Erro Yahoo Chart");const result=data?.chart?.result?.[0];if(!result)throw new Error("Sem resultado chart");const meta=result.meta||{},timestamps=result.timestamp||[],quote=result.indicators?.quote?.[0]||{},closes=quote.close||[];let i=closes.length-1;while(i>=0&&!finite(closes[i]))i--;const cleanCloses=closes.filter(finite).map(Number);const price=n(meta.regularMarketPrice)??n(closes[i]);const prevClose=n(meta.chartPreviousClose)??n(meta.previousClose);const change=finite(price)&&finite(prevClose)?Number(price)-Number(prevClose):null;const changePercent=finite(change)&&finite(prevClose)&&Number(prevClose)!==0?Number(change)/Number(prevClose)*100:null;const vols=Array.isArray(quote.volume)?quote.volume.reduce((s,v)=>s+(finite(v)?Number(v):0),0):null;const highs=Array.isArray(quote.high)?quote.high.filter(finite).map(Number):[],lows=Array.isArray(quote.low)?quote.low.filter(finite).map(Number):[],opens=Array.isArray(quote.open)?quote.open.filter(finite).map(Number):[];return{symbol:configuredSymbol,price,change,changePercent,open:n(meta.regularMarketOpen)??(opens.length?opens[0]:null),high:n(meta.regularMarketDayHigh)??(highs.length?Math.max(...highs):null),low:n(meta.regularMarketDayLow)??(lows.length?Math.min(...lows):null),prevClose,volume:n(meta.regularMarketVolume)??(vols||null),time:qTime(meta.regularMarketTime)??qTime(timestamps[i]),marketState:meta.marketState||null,history:cleanCloses.slice(-80),provider,error:null}}
  function normalizeGenericQuote(q,symbol,provider){const price=n(q.price??q.regularMarketPrice??q.last??q.close),prevClose=n(q.prevClose??q.previousClose??q.regularMarketPreviousClose);const change=n(q.change??q.regularMarketChange)??(finite(price)&&finite(prevClose)?Number(price)-Number(prevClose):null);const changePercent=n(q.changePercent??q.regularMarketChangePercent)??(finite(change)&&finite(prevClose)&&Number(prevClose)!==0?Number(change)/Number(prevClose)*100:null);const t=q.time??q.timestamp??q.regularMarketTime;return{symbol,price,change,changePercent,open:n(q.open??q.regularMarketOpen),high:n(q.high??q.regularMarketDayHigh),low:n(q.low??q.regularMarketDayLow),prevClose,volume:n(q.volume??q.regularMarketVolume),time:typeof t==="number"?qTime(t):(t?new Date(t):null),history:Array.isArray(q.history)?q.history.filter(finite).map(Number).slice(-80):[],provider,error:null}}
  async function fetchYahooChartOne(instrument){const symbols=[instrument.symbol,...(instrument.altSymbols||[])],attempts=[];for(const symbol of symbols){attempts.push({symbol,url:yahooChartUrl(symbol,"1d","1m")});attempts.push({symbol,url:yahooChartUrl(symbol,"5d","1d")})}let last=null;for(const a of attempts){try{const{json,provider}=await fetchJsonViaFallback(a.url);const q=extractChartQuote(json,instrument.symbol,`${provider} / ${a.symbol}`);if(!finite(q.price))throw new Error("Sem preço na resposta");return{...instrument,...q}}catch(e){last=e}}return{...instrument,...EMPTY,error:last?.message||"Falha ao obter cotação"}}
  async function fetchCustomWorkerOne(instrument){const base=(localStorage.getItem("psi.workerUrl")||"").trim().replace(/\/$/,"");if(!base)return{...instrument,...EMPTY,error:"Proxy próprio não configurado"};const symbols=[instrument.symbol,...(instrument.altSymbols||[])];let last=null;for(const symbol of symbols){try{const text=await fetchText(`${base}/quote?symbol=${encodeURIComponent(symbol)}`);const data=parseJson(text);const q=data.chart?extractChartQuote(data,instrument.symbol,`Proxy próprio / ${symbol}`):normalizeGenericQuote(data,instrument.symbol,`Proxy próprio / ${symbol}`);if(!finite(q.price))throw new Error("Sem preço na resposta");return{...instrument,...q}}catch(e){last=e}}return{...instrument,...EMPTY,error:last?.message||"Falha no proxy próprio"}}
  async function mapLimit(items,limit,worker,onProgress){const results=new Array(items.length);let next=0,done=0;async function run(){while(next<items.length){const idx=next++;results[idx]=await worker(items[idx]);done++;onProgress?.(done,items.length,results[idx])}}await Promise.all(Array.from({length:Math.min(limit,items.length)},run));return results}
  async function fetchAllQuotes(){const provider=$("providerSelect").value;const worker=provider==="custom-worker"?fetchCustomWorkerOne:fetchYahooChartOne;return await mapLimit([INDEX,...COMPONENTS],4,worker,(done,total,item)=>{setStatus("warn",`A atualizar ${done}/${total}`);if(item.symbol===INDEX.symbol)state.index=item;else{const idx=state.rows.findIndex(r=>r.symbol===item.symbol);if(idx>=0)state.rows[idx]=item}renderAll(false)})}
  function applyFetched(results){state.index=results.find(r=>r.symbol===INDEX.symbol)||{...INDEX,...EMPTY,error:"Sem dados do índice"};const map=new Map(results.filter(r=>r.symbol!==INDEX.symbol).map(r=>[r.symbol,r]));state.rows=COMPONENTS.map(c=>map.get(c.symbol)||{...c,...EMPTY,error:"Sem dados"})}
  function selectedRow(){return state.rows.find(r=>r.symbol===state.selectedSymbol)||state.rows[0]||{...COMPONENTS[0],...EMPTY}}
  function filteredRows(){const q=$("searchInput").value.trim().toLowerCase(),filter=$("filterSelect").value;let rows=state.rows.filter(r=>!q||[r.name,r.symbol,r.isin].some(x=>String(x||"").toLowerCase().includes(q)));rows=rows.filter(r=>filter==="up"?finite(r.changePercent)&&Number(r.changePercent)>0:filter==="down"?finite(r.changePercent)&&Number(r.changePercent)<0:filter==="with-data"?!r.error&&finite(r.price):filter==="errors"?Boolean(r.error):true);const key=state.sortKey,dir=state.sortDir==="asc"?1:-1;rows.sort((a,b)=>{const av=a[key],bv=b[key];if(typeof av==="string"||typeof bv==="string")return String(av||"").localeCompare(String(bv||""),"pt-PT")*dir;const an=finite(av)?Number(av):-Infinity,bn=finite(bv)?Number(bv):-Infinity;return(an-bn)*dir});return rows}
  function buildPath(values,w,h,pad=4){const arr=(values||[]).filter(finite).map(Number);if(arr.length<2)return null;const min=Math.min(...arr),max=Math.max(...arr),spread=max-min||1,step=(w-pad*2)/(arr.length-1);const pts=arr.map((v,i)=>[pad+i*step,h-pad-((v-min)/spread)*(h-pad*2)]);const d=pts.map(([x,y],i)=>`${i?"L":"M"}${x.toFixed(2)},${y.toFixed(2)}`).join(" ");return{d,fill:`${d} L${(w-pad).toFixed(2)},${(h-pad).toFixed(2)} L${pad},${(h-pad).toFixed(2)} Z`}}
  function miniSpark(row){const k=cls(row.changePercent),color=k==="pos"?"var(--green)":k==="neg"?"var(--red)":"var(--muted)";const p=buildPath(row.history,74,30);if(!p)return `<span class="flat" style="font-family:var(--mono);font-size:.68rem">sem gráfico</span>`;return `<svg viewBox="0 0 74 30"><path class="fill" d="${p.fill}" fill="${color}"></path><path d="${p.d}" stroke="${color}"></path></svg>`}
  function bigChart(row){const k=cls(row.changePercent),color=k==="pos"?"var(--green)":k==="neg"?"var(--red)":"var(--muted)";const p=buildPath(row.history,340,136,8);if(!p)return `<div style="height:100%;display:grid;place-items:center;color:var(--muted);font-family:var(--mono)">Sem histórico intraday</div>`;return `<svg viewBox="0 0 340 136"><line class="grid-line" x1="8" x2="332" y1="34" y2="34"/><line class="grid-line" x1="8" x2="332" y1="68" y2="68"/><line class="grid-line" x1="8" x2="332" y1="102" y2="102"/><path class="chart-fill" d="${p.fill}" fill="${color}"></path><path class="chart-path" d="${p.d}" stroke="${color}"></path></svg>`}
  function syntheticBidAsk(row){if(!finite(row.price))return{bid:null,ask:null,spread:null};const p=Number(row.price),spread=Math.max(p*.0012,.0002);return{bid:p-spread/2,ask:p+spread/2,spread}}
  function renderStats(){const idx=state.index,ok=state.rows.filter(r=>!r.error&&finite(r.price)).length,withChange=state.rows.filter(r=>finite(r.changePercent)),up=withChange.filter(r=>Number(r.changePercent)>0).length,down=withChange.filter(r=>Number(r.changePercent)<0).length,volume=state.rows.reduce((s,r)=>s+(finite(r.volume)?Number(r.volume):0),0);$("mIndex").innerHTML=finite(idx.price)?`${fNum(idx.price)} <span class="${cls(idx.changePercent)}">${fPct(idx.changePercent)}</span>`:"—";$("mState").textContent=`Mercado ${idx.marketState||"—"}`;$("mBreadth").innerHTML=withChange.length?`${up}<span class="pos">↑</span> ${down}<span class="neg">↓</span>`:"—";$("mBreadthNote").textContent=withChange.length?`${withChange.length} com variação` : "Sem variações";$("mQuality").textContent=`${ok}/${state.rows.length}`;$("mSource").textContent=$("providerSelect").value==="custom-worker"?"Proxy próprio":"Yahoo Chart";$("mVolume").textContent=volume?fVol(volume):"—"}
  function renderTape(){const rows=state.rows.filter(r=>finite(r.price));$("tickerTape").innerHTML=rows.length?rows.map(r=>`<span class="tape-item" data-symbol="${escapeHtml(r.symbol)}"><span class="tape-symbol">${escapeHtml(shortSymbol(r.symbol))}</span><span>${fPlain(r.price)}</span><span class="${cls(r.changePercent)}">${fPct(r.changePercent)}</span></span>`).join(""):`<span class="tape-item">Sem cotações ainda · toca em atualizar</span>`}
  function renderWatchlist(){const rows=filteredRows();$("quoteList").innerHTML=rows.map(r=>`<button class="quote-card ${r.symbol===state.selectedSymbol?"selected":""}" data-symbol="${escapeHtml(r.symbol)}" type="button"><div class="q-main"><div class="q-symbol">${escapeHtml(shortSymbol(r.symbol))}</div><div class="q-name">${escapeHtml(r.name)}</div></div><div><div class="q-price">${fPlain(r.price)}</div><div class="q-change ${cls(r.changePercent)}">${fPct(r.changePercent)}</div></div><div class="spark">${miniSpark(r)}</div></button>`).join("")||`<div class="settings-card"><p class="small-copy">Sem resultados para o filtro atual.</p></div>`}
  function renderDetail(){const r=selectedRow();$("selectedLogo").textContent=initials(r.name);$("selectedSymbol").textContent=shortSymbol(r.symbol);$("selectedName").textContent=r.name||"—";$("selectedStatus").textContent=r.error?"Erro":finite(r.price)?"Ativo":"Por atualizar";$("selectedStatus").className=`status-chip ${r.error?"neg":finite(r.price)?"pos":"flat"}`;$("selectedPrice").textContent=fEUR(r.price);$("selectedChange").className=`change-pill ${cls(r.changePercent)}`;$("selectedChange").textContent=`${finite(r.change)&&Number(r.change)>0?"+":""}${fNum(r.change)} · ${fPct(r.changePercent)}`;$("bigChart").innerHTML=bigChart(r);$("selectedOpen").textContent=fEUR(r.open);$("selectedHigh").textContent=fEUR(r.high);$("selectedLow").textContent=fEUR(r.low);$("selectedPrev").textContent=fEUR(r.prevClose);$("selectedVolume").textContent=fVol(r.volume);$("selectedTime").textContent=tText(r.time);$("selectedIsin").textContent=r.isin||"—";$("selectedProvider").textContent=r.provider||r.error||"—";$("googleLink").href=`https://www.google.com/finance/quote/${encodeURIComponent(r.google)}`;$("yahooLink").href=`https://finance.yahoo.com/quote/${encodeURIComponent(r.symbol)}/`;$("euronextLink").href=r.euronext||"#";$("ticketSymbol").value=shortSymbol(r.symbol);if(finite(r.price)&&!$("ticketLimit").value)$("ticketLimit").value=Number(r.price).toFixed(4);renderTicketEstimate();renderBook(r);renderActivity(r)}
  function renderTicketEstimate(){const price=n($("ticketLimit").value)??selectedRow().price,qty=n($("ticketQty").value)??0;$("ticketEstimate").textContent=finite(price)&&finite(qty)?fEUR(Number(price)*Number(qty)):"—"}
  function renderBook(row){if(!finite(row.price)){ $("orderBook").innerHTML=`<div class="note">Sem preço para construir bid/ask.</div>`;return } const p=Number(row.price),spread=Math.max(p*.0012,.0002);const bids=Array.from({length:6},(_,i)=>({px:p-spread*(i+.5),qty:Math.round(900+i*320)}));const asks=Array.from({length:6},(_,i)=>({px:p+spread*(i+.5),qty:Math.round(850+i*300)}));const maxQty=Math.max(...bids.map(x=>x.qty),...asks.map(x=>x.qty));const table=(title,rows,k)=>`<table><thead><tr><th colspan="2">${title}</th></tr></thead><tbody>${rows.map(x=>`<tr><td class="${k}">${fPlain(x.px)}<div class="depth"><span style="width:${Math.round(x.qty/maxQty*100)}%;background:${k==="pos"?"var(--green)":"var(--red)"}"></span></div></td><td>${fVol(x.qty)}</td></tr>`).join("")}</tbody></table>`;$("orderBook").innerHTML=table("BID",bids,"pos")+table("ASK",asks,"neg")}
  function renderActivity(row){const ba=syntheticBidAsk(row),now=new Date().toLocaleTimeString("pt-PT",{hour:"2-digit",minute:"2-digit",second:"2-digit"});const items=[{t:`${shortSymbol(row.symbol)} selecionado`,m:`${now} · ${row.name}`},{t:finite(row.price)?`Último ${fEUR(row.price)} · ${fPct(row.changePercent)}`:"Sem preço disponível",m:row.provider||row.error||"Por atualizar"},{t:finite(ba.bid)?`Bid ${fPlain(ba.bid)} / Ask ${fPlain(ba.ask)}`:"Bid/Ask indisponível",m:"spread estimado pela interface"},{t:"Execução real bloqueada",m:"sem ligação a corretora"}];$("activityLog").innerHTML=items.map(i=>`<div class="log-item"><div class="log-title">${escapeHtml(i.t)}</div><div class="log-meta">${escapeHtml(i.m)}</div></div>`).join("")}
  function renderAll(full=true){renderStats();renderTape();renderWatchlist();renderDetail()}
  function setStatus(type,text){$("statusDot").className=`dot ${type==="ok"?"ok":type==="bad"?"bad":""}`;$("statusText").textContent=text}
  async function refresh(){if(state.refreshing)return;state.refreshing=true;$("refreshBtn").disabled=true;$("floatRefresh").disabled=true;$("testBtn").disabled=true;setStatus("warn","A atualizar…");try{const results=await fetchAllQuotes();applyFetched(results);renderAll(true);$("lastUpdate").textContent=new Date().toLocaleTimeString("pt-PT",{hour:"2-digit",minute:"2-digit",second:"2-digit"});const missing=state.rows.filter(r=>r.error||!finite(r.price)).length,ok=state.rows.length-missing;setStatus(missing?"warn":"ok",missing?`${ok}/${state.rows.length}`:"Online")}catch(e){console.error(e);setStatus("bad",e.message||"Falha")}finally{state.refreshing=false;$("refreshBtn").disabled=false;$("floatRefresh").disabled=false;$("testBtn").disabled=false}}
  async function testSource(){setStatus("warn","Teste EDP…");$("testBtn").disabled=true;try{const edp=COMPONENTS.find(c=>c.symbol==="EDP.LS"),r=$("providerSelect").value==="custom-worker"?await fetchCustomWorkerOne(edp):await fetchYahooChartOne(edp);if(r.error)throw new Error(r.error);setStatus("ok",`EDP ${fEUR(r.price)}`)}catch(e){setStatus("bad",`Falhou`);alert(`Teste da fonte falhou:\n${e.message}`)}finally{$("testBtn").disabled=false}}
  function schedule(){if(state.timer)clearInterval(state.timer);const s=Number($("intervalSelect").value);if(s>0)state.timer=setInterval(refresh,s*1000)}
  function exportCsv(){const headers=["Empresa","Simbolo","ISIN","Preco","Variacao","Percentagem","Abertura","Maximo","Minimo","FechoAnterior","Volume","Hora","Fonte","Erro"];const lines=[headers,...state.rows.map(r=>[r.name,r.symbol,r.isin,r.price,r.change,r.changePercent,r.open,r.high,r.low,r.prevClose,r.volume,r.time instanceof Date?r.time.toISOString():"",r.provider,r.error])].map(row=>row.map(c=>`"${String(c??"").replaceAll('"','""')}"`).join(","));const blob=new Blob([lines.join("\n")],{type:"text/csv;charset=utf-8"});const url=URL.createObjectURL(blob);const a=document.createElement("a");a.href=url;a.download=`cotacoes-psi-mobile-${new Date().toISOString().slice(0,10)}.csv`;document.body.appendChild(a);a.click();a.remove();URL.revokeObjectURL(url)}
  function switchTab(tab){state.tab=tab;document.querySelectorAll(".panel").forEach(p=>p.classList.remove("active"));$("panel-"+tab).classList.add("active");document.querySelectorAll(".tab-btn").forEach(b=>b.classList.toggle("active",b.dataset.tab===tab))}
  function selectSymbol(symbol,openDetail=true){if(!symbol)return;state.selectedSymbol=symbol;const row=state.rows.find(r=>r.symbol===symbol);if(row&&finite(row.price))$("ticketLimit").value=Number(row.price).toFixed(4);renderAll(true);if(openDetail)switchTab("detail")}
  function initWorkerCode(){$("workerCode").textContent=`export default {
  async fetch(request) {
    const u = new URL(request.url);
    const symbol = u.searchParams.get("symbol") || "EDP.LS";
    const target = "https://query2.finance.yahoo.com/v8/finance/chart/" + encodeURIComponent(symbol) + "?range=1d&interval=1m&includePrePost=false&events=history&corsDomain=finance.yahoo.com";
    const r = await fetch(target, { headers: { "User-Agent": "Mozilla/5.0", "Accept": "application/json" } });
    const body = await r.text();
    return new Response(body, { status: r.status, headers: { "content-type": "application/json; charset=utf-8", "access-control-allow-origin": "*", "cache-control": "no-store" } });
  }
};`}
  function initEvents(){["refreshBtn","floatRefresh"].forEach(id=>$(id).addEventListener("click",refresh));$("testBtn").addEventListener("click",testSource);$("exportBtn").addEventListener("click",exportCsv);$("providerSelect").addEventListener("change",refresh);$("intervalSelect").addEventListener("change",schedule);$("searchInput").addEventListener("input",()=>renderAll(true));$("filterSelect").addEventListener("change",()=>renderAll(true));$("ticketQty").addEventListener("input",renderTicketEstimate);$("ticketLimit").addEventListener("input",renderTicketEstimate);$("buyTab").addEventListener("click",()=>{state.side="buy";$("buyTab").style.outline="2px solid var(--green)";$("sellTab").style.outline="0"});$("sellTab").addEventListener("click",()=>{state.side="sell";$("sellTab").style.outline="2px solid var(--red)";$("buyTab").style.outline="0"});document.body.addEventListener("click",ev=>{const row=ev.target.closest("[data-symbol]");if(row)selectSymbol(row.dataset.symbol,true)});document.querySelectorAll(".tab-btn").forEach(btn=>btn.addEventListener("click",()=>switchTab(btn.dataset.tab)));document.querySelectorAll("[data-sortquick]").forEach(btn=>btn.addEventListener("click",()=>{const k=btn.dataset.sortquick;state.sortKey=k;state.sortDir=k==="name"?"asc":"desc";document.querySelectorAll("[data-sortquick]").forEach(b=>b.classList.toggle("active",b===btn));renderAll(true)}));$("themeBtn").addEventListener("click",()=>{const root=document.documentElement,next=root.dataset.theme==="dark"?"light":"dark";root.dataset.theme=next;$("themeBtn").textContent=next==="dark"?"Tema claro":"Tema escuro";localStorage.setItem("psi.mobile.theme",next)});$("workerBtn").addEventListener("click",()=>{$("workerUrlInput").value=localStorage.getItem("psi.workerUrl")||"";$("workerDialog").showModal()});$("closeWorkerBtn").addEventListener("click",()=>$("workerDialog").close());$("saveWorkerBtn").addEventListener("click",()=>{localStorage.setItem("psi.workerUrl",$("workerUrlInput").value.trim().replace(/\/$/,""));$("workerDialog").close();$("providerSelect").value="custom-worker";refresh()})}
  function init(){const theme=localStorage.getItem("psi.mobile.theme");if(theme){document.documentElement.dataset.theme=theme;$("themeBtn").textContent=theme==="dark"?"Tema claro":"Tema escuro"}initWorkerCode();initEvents();renderAll(true);schedule();refresh()}
  init();

  function initPwaInstall(){
    if(window.matchMedia && window.matchMedia('(display-mode: standalone)').matches){document.body.classList.add('standalone')}
    const installBtn = document.getElementById('installAppBtn');
    let deferredPrompt = null;
    if('serviceWorker' in navigator){window.addEventListener('load',()=>navigator.serviceWorker.register('./sw.js').catch(()=>{}));}
    window.addEventListener('beforeinstallprompt', ev=>{ev.preventDefault();deferredPrompt=ev;if(installBtn)installBtn.classList.add('show')});
    if(installBtn){installBtn.addEventListener('click', async ()=>{try{if(deferredPrompt){deferredPrompt.prompt();await deferredPrompt.userChoice;deferredPrompt=null;installBtn.classList.remove('show')}else{alert('Para instalar no Android: abre esta pasta num servidor HTTPS e, no Chrome, usa Menu ⋮ → Adicionar ao ecrã principal / Instalar app.')}}catch(e){alert('Não foi possível abrir o instalador: '+e.message)}})}
    window.addEventListener('appinstalled',()=>{if(installBtn)installBtn.classList.remove('show');document.body.classList.add('standalone')});
  }
  initPwaInstall();
  </script>
</body>
</html>
